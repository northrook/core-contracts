{
  "name": "northrook/core-contracts",
  "description": "A set of Interfaces, Traits, and abstract Services for decoupled package integration.",
  "type": "library",
  "license": "BSD-3-Clause",
  "authors": [
      {
          "name": "Martin Nielsen",
          "email": "mn@northrook.com",
          "role": "Developer"
      }
  ],
  "autoload": {
      "psr-4": {
          "Northrook\\": "src"
      },
      "files": [
          "src/constants.php",
          "src/functions.php"
      ]
  },
  "autoload-dev": {
      "psr-4": {
          "Northrook\\Contracts\\Tests\\": "tests/"
      },
      "classmap": [
          "tests/TraitsForAnalysis.php"
      ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
      "php": ">=8.4",
      "psr/log": "@stable",
      "psr/cache": "@stable",
      "psr/container": "@stable",
      "psr/event-dispatcher": "@stable",
      "symfony/http-client-contracts": "^3.7"
  },
  "require-dev": {
      "northrook/php-cs": "dev-main",
      "phpunit/phpunit": "^11.5",
      "phpstan/phpstan": "^2.2"
  },
  "scripts": {
      "phpstan": "vendor/bin/phpstan analyse",
      "test": "vendor/bin/phpunit",
      "php-cs-config": "vendor/bin/php-cs-config",
      "collision": "vendor/bin/collision-check"
  }
}
