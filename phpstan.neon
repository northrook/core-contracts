includes:
	- vendor/northrook/php-cs/extension.neon
parameters:
	paths:
		- src
		- tests
	excludePaths:
		- tests/Support/InvalidAutodiscoverCalls.php
		- tests/Support/InvalidValidationCalls.php
		- tests/Support/InvalidRegexpCalls.php
	ignoreErrors:
		-
			# Late static binding is intentional; subclasses with other constructors override create().
			identifier: new.static
			path: src/Contracts/Singleton.php
